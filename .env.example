# Al-Rabb Tours & Travels - Environment Variables

# Django Settings
DEBUG=True
SECRET_KEY=generate_a_strong_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1,api.alrabbtours.com

# Database
DB_USER=alrabb
DB_PASSWORD=supersecret
DB_NAME=alrabb_db
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgres://alrabb:supersecret@db:5432/alrabb_db

# Redis & Celery
REDIS_URL=redis://redis:6379/0

# Storage (AWS S3 or Cloudflare R2)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_STORAGE_BUCKET_NAME=alrabb-documents
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# Email (Resend or SES)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=your_resend_api_key
DEFAULT_FROM_EMAIL=noreply@alrabbtours.com

# Frontend URL (for CORS)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://alrabbtours.com
